# Backend — variables de entorno
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas el archivo .env al repositorio.

# Puerto en el que arranca el servidor
PORT=

# Entorno de ejecución: development (local) o production (servidor)
NODE_ENV=

# Conexión a la base de datos MySQL
DB_HOST=
DB_PORT=
DB_USER=
DB_PASSWORD=
DB_NAME=

# Clave secreta para firmar los tokens JWT
JWT_SECRET=

# URL del frontend permitida por CORS (sin barra al final)
CORS_ORIGIN=
