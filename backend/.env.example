# ── Backend — variables de entorno ──────────────────────────────────────────
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas .env al repositorio.

# Puerto del servidor (Render lo sobreescribe automáticamente)
PORT=4000

# Entorno: "development" en local, "production" en Render
NODE_ENV=development

# Base de datos MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=tu_usuario_mysql
DB_PASSWORD=tu_password_mysql
DB_NAME=padex_db

# Secreto para firmar JWT — usa uno largo y aleatorio en producción:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=cambia_esto_por_un_secreto_largo_y_aleatorio

# Origen permitido por CORS (URL exacta del frontend en Vercel, sin barra final)
# En local puedes dejarlo vacío — localhost:5173 ya está permitido en el código
CORS_ORIGIN=https://tu-app.vercel.app
